# Colosseum — source-only backup. Build output, scratch, and downloadable art stay out.

# CMake / compiler output (recompiles from native/main.cpp + CMakeLists.txt)
# build*/ covers both the MinGW build/ and the MSVC build-msvc/ trees.
native/build*/

# Dev scratch: smoke screenshots, diagnostic logs, click scripts
tools/
*-proto.png
mocks/*-shot.png
.codex-history/

# Cover art — fetched from remote URLs (Catalog.js) + cached to disk; not source
assets/covers/

# OS / editor cruft
*.log
Thumbs.db
.DS_Store
